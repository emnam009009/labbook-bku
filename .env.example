# Firebase configuration
# Lấy từ Firebase Console → Project Settings → General → Your apps → Web app
# Get these from Firebase Console → Project Settings → General → Your apps → Web app

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# ============================================================
# AI MODULE (Round 105+)
# ============================================================
# These are referenced by Cloud Functions, NOT exposed to client.
# Client never sees these keys directly. All AI calls go through
# Cloud Functions which read these from Firebase Functions config
# or GCP Secret Manager.
#
# To set in Firebase:
#   firebase functions:config:set anthropic.api_key="sk-ant-..."
#   firebase functions:config:set voyage.api_key="pa-..."
#   firebase functions:config:set chandra.api_key="..."
#   firebase functions:config:set gemini.api_key="..."
#
# For local development with emulator:
#   functions/.env (Firebase emulator reads this)

# Anthropic Claude API (Tier 2-3 LLM, vision, citations)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini API (Tier 1 LLM, free tier 1500 RPD)
GEMINI_API_KEY=AIza...

# Voyage AI (embeddings + reranking)
VOYAGE_API_KEY=pa-...

# Chandra OCR (datalab.to hosted API for PDF/handwriting)
CHANDRA_API_KEY=...

# Optional: Cohere (fallback reranker)
# COHERE_API_KEY=...

# ============================================================
# Python Service (Cloud Run, Round 107+)
# ============================================================
# URL of FastAPI service deployed on Cloud Run
PYTHON_SERVICE_URL=https://labbook-python-xxx-asia-southeast1.a.run.app
PYTHON_SERVICE_API_KEY=internal-shared-secret

# ============================================================
# AI Module Feature Flags (gradual rollout)
# ============================================================
VITE_AI_ENABLED=false
VITE_AI_TIER_2_ENABLED=false
VITE_AI_TIER_3_ENABLED=false
VITE_AI_VOICE_ENABLED=false

# AI Module Limits (per-user per-day, enforced server-side)
VITE_AI_MAX_QUERIES_PER_DAY=200
VITE_AI_MAX_TIER_3_PER_DAY=20
