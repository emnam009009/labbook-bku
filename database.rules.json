{
  "rules": {

    "users": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin')",
      ".indexOn": ["email", "role"],

      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin')",

        ".write": "auth != null && (($uid === auth.uid && (!data.exists() || (newData.child('role').val() === data.child('role').val() && newData.child('email').val() === data.child('email').val()))) || ($uid !== auth.uid && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin')))",

        ".validate": "newData.hasChildren(['email','role']) && newData.child('email').isString() && newData.child('role').isString() && (newData.child('role').val() === 'pending' || newData.child('role').val() === 'rejected' || newData.child('role').val() === 'viewer' || newData.child('role').val() === 'member' || newData.child('role').val() === 'admin' || newData.child('role').val() === 'superadmin')",

        "role": {
          ".validate": "(!data.exists() && newData.val() === 'pending') || (data.exists() && newData.val() === data.val()) || (auth != null && $uid !== auth.uid && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin') && (newData.val() !== 'superadmin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin'))"
        },

        "email":     { ".validate": "newData.isString() && newData.val().length <= 200" },
        "name":      { ".validate": "newData.isString() && newData.val().length <= 100" },
        "displayName": { ".validate": "newData.isString() && newData.val().length <= 100" },
        "avatar":    { ".validate": "newData.isString() && newData.val().length <= 200000" },
        "createdAt": { ".validate": "newData.isNumber()" },

        "$other": { ".validate": true }
      }
    },

    "hydro": {
      ".indexOn": ["createdAt", "person", "code", "date"],
      ".read":  "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'pending' && root.child('users').child(auth.uid).child('role').val() !== 'rejected'",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'member' || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin')",
      "$id": {
        ".validate": "newData.hasChildren(['createdAt']) || data.exists()"
      }
    },

    "electrode": {
      ".indexOn": ["createdAt", "person", "code", "date"],
      ".read":  "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'pending' && root.child('users').child(auth.uid).child('role').val() !== 'rejected'",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'member' || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin')"
    },

    "electrochem": {
      ".indexOn": ["createdAt", "person", "code", "date"],
      ".read":  "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'pending' && root.child('users').child(auth.uid).child('role').val() !== 'rejected'",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'member' || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin')"
    },

    "ink": {
      ".indexOn": ["createdAt", "person", "code"],
      ".read":  "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'pending' && root.child('users').child(auth.uid).child('role').val() !== 'rejected'",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'member' || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin')"
    },

    "chemicals": {
      ".indexOn": ["name", "groupId"],
      ".read":  "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'pending' && root.child('users').child(auth.uid).child('role').val() !== 'rejected'",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin')"
    },

    "groups": {
      ".read":  "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'pending' && root.child('users').child(auth.uid).child('role').val() !== 'rejected'",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin')"
    },

    "equipment": {
      ".indexOn": ["name", "groupId"],
      ".read":  "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'pending' && root.child('users').child(auth.uid).child('role').val() !== 'rejected'",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin')"
    },

    "eq_groups": {
      ".read":  "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'pending' && root.child('users').child(auth.uid).child('role').val() !== 'rejected'",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin')"
    },

    "members": {
      ".indexOn": ["name", "email", "role"],
      ".read":  "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'pending' && root.child('users').child(auth.uid).child('role').val() !== 'rejected'",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'member' || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin')"
    },

    "bookings": {
      ".indexOn": ["date", "userId", "equipmentId", "status", "createdAt"],
      ".read":  "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'pending' && root.child('users').child(auth.uid).child('role').val() !== 'rejected'",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'member' || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin')"
    },

    "notifications": {
      "$uid": {
        ".read":  "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin' || root.child('users').child(auth.uid).child('role').val() === 'member')",
        ".indexOn": ["ts", "read"]
      }
    },

    "history": {
      ".read":  "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin')",
      ".indexOn": ["ts", "uid"],

      "$id": {
        ".write": "auth != null && !data.exists() && (root.child('users').child(auth.uid).child('role').val() === 'member' || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin')",

        ".validate": "newData.hasChildren(['ts','uid','action']) && newData.child('uid').val() === auth.uid && newData.child('ts').isNumber() && newData.child('ts').val() <= now + 60000 && newData.child('ts').val() >= now - 60000 && newData.child('action').isString() && newData.child('action').val().length > 0 && newData.child('action').val().length <= 200",

        "ts":     { ".validate": "newData.isNumber()" },
        "uid":    { ".validate": "newData.isString() && newData.val() === auth.uid" },
        "email":  { ".validate": "newData.isString() && newData.val().length <= 200" },
        "action": { ".validate": "newData.isString() && newData.val().length <= 200" },
        "detail": { ".validate": "newData.isString() && newData.val().length <= 2000" },
        "$other": { ".validate": false }
      }
    },

    "settings": {
      ".read":  "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin')"
    },

    "chat": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'pending' && root.child('users').child(auth.uid).child('role').val() !== 'rejected'",

      "messages": {
        ".indexOn": ["ts"],
        "$msgId": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'member' || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin') && ((!data.exists() && newData.child('uid').val() === auth.uid) || (data.exists() && data.child('uid').val() === auth.uid) || root.child('users').child(auth.uid).child('role').val() === 'superadmin')",

          ".validate": "newData.hasChildren(['uid','ts','text']) && newData.child('uid').val() === auth.uid && newData.child('ts').isNumber() && newData.child('text').isString() && newData.child('text').val().length <= 5000",

          "reactions": {
            ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'pending' && root.child('users').child(auth.uid).child('role').val() !== 'rejected'"
          }
        }
      },

      "typing": {
        "$uid": {
          ".write": "auth != null && $uid === auth.uid"
        }
      }
    },

    "presence": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['online'])",
        "online":   { ".validate": "newData.isBoolean()" },
        "lastSeen": { ".validate": "newData.isNumber()" },
        "$other":   { ".validate": false }
      }
    }
  }
}
