# ============================================================
# Cloud Functions Local Emulator Configuration
# ============================================================
# These vars are used ONLY by Firebase emulator for local dev.
# Production secrets are set via:
#   firebase functions:config:set anthropic.api_key="sk-ant-..."
# OR (preferred for v2):
#   firebase functions:secrets:set ANTHROPIC_API_KEY
#
# ============================================================

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-test-...

# Google Gemini API
GEMINI_API_KEY=AIza-test-...

# Voyage AI
VOYAGE_API_KEY=pa-test-...

# Chandra OCR
CHANDRA_API_KEY=test-...

# Python service URL (Round 107+)
PYTHON_SERVICE_URL=http://localhost:8000
PYTHON_SERVICE_API_KEY=local-test-secret
