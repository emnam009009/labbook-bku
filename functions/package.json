{
  "name": "labbook-functions",
  "description": "Cloud Functions for LabBook BKU AI module",
  "main": "lib/index.js",
  "type": "commonjs",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "eslint --ext .js,.ts .",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "deploy:claude-proxy": "firebase deploy --only functions:claudeProxy",
    "logs": "firebase functions:log",
    "logs:tail": "firebase functions:log --only claudeProxy"
  },
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.6.0"
  },
  "private": true
}
