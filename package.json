{
  "name": "labbook-bku",
  "version": "1.0.0",
  "description": "LabBook — Hệ thống quản lý Lab Vật liệu BKU",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:emu": "VITE_USE_EMULATOR=true vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "emulators": "firebase emulators:start --import=./emulator-data --export-on-exit",
    "deploy:rules": "firebase deploy --only database",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "deploy:all": "npm run build && firebase deploy --only hosting,database"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "firebase": "^12.12.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "ogl": "^1.0.11",
    "pdfmake": "^0.3.7",
    "qrcode": "^1.5.4",
    "xlsx": "^0.18.5"
  }
}
