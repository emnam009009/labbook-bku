{
  "name": "labbook-bku",
  "version": "1.0.0",
  "description": "LabBook — Hệ thống quản lý Lab Vật liệu BKU",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:emu": "VITE_USE_EMULATOR=true vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "emulators": "firebase emulators:start --import=./emulator-data --export-on-exit",
    "deploy:rules": "firebase deploy --only database,storage",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "deploy:all": "npm run build && firebase deploy --only hosting,database",
    "deploy:storage": "firebase deploy --only storage",
    "migrate:notifications": "node scripts/migrate-notifications-r122.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/node": "^20.0.0",
    "autoprefixer": "^10.4.0",
    "firebase-admin": "^13.0.0",
    "postcss": "^8.4.0",
    "subset-font": "^2.5.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@fontsource/noto-sans": "^5.2.10",
    "chart.js": "^4.5.1",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "dompurify": "^3.2.0",
    "firebase": "^12.12.0",
    "highlight.js": "^11.10.0",
    "jspdf": "^4.2.1",
    "katex": "^0.16.45",
    "marked": "^15.0.0",
    "marked-katex-extension": "^5.1.8",
    "ogl": "^1.0.11",
    "pdfmake": "^0.3.7",
    "qrcode": "^1.5.4",
    "xlsx": "^0.18.5"
  }
}
