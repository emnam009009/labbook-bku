# ============================================================
# Python Service Local Development
# ============================================================
# Production secrets are managed via GCP Secret Manager.
# This file is for LOCAL DEVELOPMENT only.

# Service config
SERVICE_NAME=labbook-python-service
LOG_LEVEL=INFO

# Auth — shared secret with Cloud Functions
# This is a simple shared-secret approach for service-to-service auth.
# In production, can switch to GCP service account ID tokens.
PYTHON_SERVICE_API_KEY=local-test-secret-change-me

# Firebase project ID (for verifying user ID tokens forwarded by Cloud Functions)
FIREBASE_PROJECT_ID=lab-manager-268a6

# Optional: ML model paths (Round 128+ when MatSciBERT)
# MATSCIBERT_MODEL_PATH=/models/matscibert

# Server config (Cloud Run sets these)
PORT=8000
HOST=0.0.0.0
